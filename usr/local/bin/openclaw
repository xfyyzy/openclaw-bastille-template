#!/bin/sh
set -eu
export HOME='${OPENCLAW_DB_DIR}'
export OPENCLAW_HOME='${OPENCLAW_DB_DIR}'
export OPENCLAW_STATE_DIR='${OPENCLAW_STATE_DIR}'
export OPENCLAW_CONFIG_PATH='${OPENCLAW_ETC_DIR}/openclaw.json'
export OPENCLAW_CONTEXT_SNAPSHOT_DIR='${OPENCLAW_CONTEXT_SNAPSHOT_DIR}'
export OPENCLAW_CONTEXT_REPO_DIR='${OPENCLAW_CONTEXT_REPO_DIR}'
export XDG_CONFIG_HOME='${OPENCLAW_STATE_DIR}/xdg/config'
export XDG_CACHE_HOME='${OPENCLAW_STATE_DIR}/xdg/cache'
export XDG_STATE_HOME='${OPENCLAW_STATE_DIR}/xdg/state'

use_proxy='${USE_PROXY}'
plugin_manifest='${OPENCLAW_STATE_DIR}/plugins.txt'
routing_config_path='${OPENCLAW_ETC_DIR}/proxy-routing.conf'
routing_loaded='no'

# Default command-level routing policy. Can be overridden by
# /usr/local/etc/openclaw/proxy-routing.conf.
direct_top_commands='tui gateway daemon cron setup onboard init help --help -h version --version logs system approvals devices secrets acp config status health sessions security skills completion doctor dashboard reset uninstall'
proxy_top_commands=''
default_route='proxy'
gateway_proxy_subcommands='run'
setup_proxy_flags='--wizard --non-interactive --mode --remote-url --remote-token'
onboard_proxy_flags='--mode --remote-url --remote-token'
plugins_direct_subcommands='list info enable disable uninstall remove doctor'
plugins_proxy_subcommands='update upgrade search'
plugins_install_path_suffixes='.ts .js .mjs .cjs .tgz .tar.gz .tar .zip'
# Keep these control commands direct even when persisted routing config is old.
# Users can still force proxy by listing a command in proxy_top_commands.
required_direct_top_commands='daemon config status health sessions security skills completion doctor dashboard reset uninstall'

run_root='${OPENCLAW_INSTALL_ROOT}/node_modules/openclaw'
if [ ! -f "${run_root}/openclaw.mjs" ]; then
  echo "openclaw entrypoint not found: ${run_root}/openclaw.mjs" >&2
  exit 1
fi

cd "${run_root}"

clear_proxy_preload_env() {
  # Direct paths talk to local services and must not inherit proxychains
  # preload injection from parent shells.
  unset LD_PRELOAD
  for _env_name in $(env | awk -F= '/^PROXYCHAINS_/ { print $1 }'); do
    unset "${_env_name}"
  done
}

# Run openclaw (non-exec) so the wrapper can post-process the result.
run_openclaw_direct() {
  clear_proxy_preload_env
  /usr/local/bin/node ./openclaw.mjs "$@"
}

run_openclaw_proxy() {
  /usr/local/bin/proxychains -q /usr/local/bin/node ./openclaw.mjs "$@"
}

exec_openclaw_direct() {
  clear_proxy_preload_env
  exec /usr/local/bin/node ./openclaw.mjs "$@"
}

exec_openclaw_proxy() {
  exec /usr/local/bin/proxychains -q /usr/local/bin/node ./openclaw.mjs "$@"
}

load_proxy_routing_config() {
  [ "${routing_loaded}" = 'yes' ] && return 0
  routing_loaded='yes'

  if [ -r "${routing_config_path}" ]; then
    # shellcheck disable=SC1090
    if ! . "${routing_config_path}"; then
      echo "warning: failed to load routing config: ${routing_config_path}" >&2
    fi
  fi

  normalize_proxy_routing_policy
}

list_has_word() {
  _list="$1"
  _needle="$2"
  case " ${_list} " in
    *" ${_needle} "*) return 0 ;;
  esac
  return 1
}

append_missing_words() {
  _list="$1"
  shift
  for _word in "$@"; do
    if ! list_has_word "${_list}" "${_word}"; then
      if [ -n "${_list}" ]; then
        _list="${_list} ${_word}"
      else
        _list="${_word}"
      fi
    fi
  done
  printf '%s' "${_list}"
}

normalize_proxy_routing_policy() {
  set -f
  # shellcheck disable=SC2086
  direct_top_commands="$(append_missing_words "${direct_top_commands}" ${required_direct_top_commands})"
  set +f
}

has_any_flag() {
  _flags="$1"
  shift
  for _arg in "$@"; do
    case "${_arg}" in
      --*=*)
        _name="${_arg%%=*}"
        if list_has_word "${_flags}" "${_name}"; then
          return 0
        fi
        ;;
      *)
        if list_has_word "${_flags}" "${_arg}"; then
          return 0
        fi
        ;;
    esac
  done
  return 1
}

first_non_option_arg() {
  shift 2
  for _arg in "$@"; do
    case "${_arg}" in
      --)
        return 1
        ;;
      -*)
        continue
        ;;
      *)
        printf '%s' "${_arg}"
        return 0
        ;;
    esac
  done
  return 1
}

looks_like_local_plugin_spec() {
  _spec="$1"
  case "${_spec}" in
    /*|./*|../*|~/*)
      return 0
      ;;
  esac

  for _suffix in ${plugins_install_path_suffixes}; do
    case "${_spec}" in
      *"${_suffix}")
        return 0
        ;;
    esac
  done

  [ -e "${_spec}" ]
}

should_proxy_openclaw() {
  top_cmd="${1:-}"
  sub_cmd="${2:-}"

  # Respect the main proxy switch first.  If proxy is globally disabled,
  # skip all command-level routing.
  [ "${use_proxy}" = "yes" ] || return 1
  load_proxy_routing_config

  # setup --wizard path can invoke onboarding flow that may touch the network.
  if [ "${top_cmd}" = "setup" ] && has_any_flag "${setup_proxy_flags}" "$@"; then
    return 0
  fi

  # onboard may switch to remote mode and require external connectivity.
  if [ "${top_cmd}" = "onboard" ] && has_any_flag "${onboard_proxy_flags}" "$@"; then
    return 0
  fi

  # gateway runtime may call external model providers.
  # `openclaw gateway` (without subcommand) behaves like `openclaw gateway run`.
  if [ "${top_cmd}" = "gateway" ]; then
    _gateway_sub="${sub_cmd}"
    if [ -z "${_gateway_sub}" ]; then
      _gateway_sub='run'
    fi
    if list_has_word "${gateway_proxy_subcommands}" "${_gateway_sub}"; then
      return 0
    fi
  fi

  if [ "${top_cmd}" = "plugins" ]; then
    if list_has_word "${plugins_direct_subcommands}" "${sub_cmd}"; then
      return 1
    fi
    if list_has_word "${plugins_proxy_subcommands}" "${sub_cmd}"; then
      return 0
    fi
    case "${sub_cmd}" in
      install|add)
        _spec="$(first_non_option_arg "$@" || true)"
        if [ -n "${_spec}" ] && looks_like_local_plugin_spec "${_spec}"; then
          return 1
        fi
        return 0
        ;;
    esac
  fi

  if list_has_word "${proxy_top_commands}" "${top_cmd}"; then
    return 0
  fi
  if list_has_word "${direct_top_commands}" "${top_cmd}"; then
    return 1
  fi

  case "${default_route}" in
    direct)
      return 1
      ;;
  esac
  # Default to proxy for runtime commands that may hit external providers.
  return 0
}

run_openclaw() {
  if should_proxy_openclaw "$@"; then
    run_openclaw_proxy "$@"
  else
    run_openclaw_direct "$@"
  fi
}

# Extract package name from an npm spec, stripping any version suffix.
# Examples: @scope/pkg@1.0 -> @scope/pkg, pkg@^2 -> pkg, pkg -> pkg
pkg_name() {
  _input="$1"
  case "${_input}" in
    @*)
      # Scoped: @scope/pkg or @scope/pkg@version
      # Strip version after the second @ (if present)
      _without_scope="${_input#*/*}"
      if [ "${_without_scope}" != "${_input}" ]; then
        # Has slash — extract @scope/name by stripping @version from the name part
        _scope="${_input%%/*}"
        _name_ver="${_input#*/}"
        _name="${_name_ver%%@*}"
        printf '%s/%s' "${_scope}" "${_name}"
      else
        printf '%s' "${_input}"
      fi
      ;;
    *)
      # Unscoped: pkg or pkg@version
      printf '%s' "${_input%%@*}"
      ;;
  esac
}

# Add a spec to the manifest, replacing any existing entry for the same package.
manifest_add() {
  _spec="$1"
  _pkg=$(pkg_name "${_spec}")
  # Remove any existing entry for this package name, then append new spec.
  if [ -f "${plugin_manifest}" ]; then
    _tmp=$(mktemp -t openclaw-manifest.XXXXXX)
    while IFS= read -r _line || [ -n "${_line}" ]; do
      _existing_pkg=$(pkg_name "${_line}")
      [ "${_existing_pkg}" = "${_pkg}" ] || printf '%s\n' "${_line}"
    done < "${plugin_manifest}" > "${_tmp}"
    mv "${_tmp}" "${plugin_manifest}"
  fi
  printf '%s\n' "${_spec}" >> "${plugin_manifest}"
}

# Remove all entries matching a package name from the manifest.
manifest_remove() {
  _spec="$1"
  _pkg=$(pkg_name "${_spec}")
  [ -f "${plugin_manifest}" ] || return 0
  _tmp=$(mktemp -t openclaw-manifest.XXXXXX)
  while IFS= read -r _line || [ -n "${_line}" ]; do
    _existing_pkg=$(pkg_name "${_line}")
    [ "${_existing_pkg}" = "${_pkg}" ] || printf '%s\n' "${_line}"
  done < "${plugin_manifest}" > "${_tmp}"
  mv "${_tmp}" "${plugin_manifest}"
}

# --- Plugin manifest hooks ---
# Intercept plugins install/uninstall to keep a persistent manifest.
# On jail rebuild, install-openclaw.sh reads this manifest to restore plugins.

case "${1:-}" in
  plugins)
    case "${2:-}" in
      install)
        run_openclaw "$@"
        _rc=$?
        if [ "${_rc}" -eq 0 ]; then
          shift 2
          for _spec in "$@"; do
            case "${_spec}" in -*) continue ;; esac
            manifest_add "${_spec}"
            echo "plugin manifest: added ${_spec}"
          done
        fi
        exit "${_rc}"
        ;;
      uninstall|remove)
        run_openclaw "$@"
        _rc=$?
        if [ "${_rc}" -eq 0 ]; then
          shift 2
          for _spec in "$@"; do
            case "${_spec}" in -*) continue ;; esac
            manifest_remove "${_spec}"
            echo "plugin manifest: removed ${_spec}"
          done
        fi
        exit "${_rc}"
        ;;
    esac
    ;;
esac

if should_proxy_openclaw "$@"; then
  exec_openclaw_proxy "$@"
else
  exec_openclaw_direct "$@"
fi
